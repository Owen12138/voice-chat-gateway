# Gateway auth — clients must send: Authorization: Bearer <this value>
VOICE_CHAT_API_KEY=change-me

# Web UI login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# STT service (stt-server)
STT_URL=http://host.docker.internal:18890/transcribe
STT_API_KEY=change-me

# Chat/LLM service (OpenAI-compatible)
CHAT_COMPLETIONS_URL=http://host.docker.internal:18789/v1/chat/completions
CHAT_API_KEY=change-me
CHAT_MODEL=openclaw/default

# TTS service (tts-proxy)
TTS_URL=http://host.docker.internal:5001/
TTS_API_KEY=change-me
DEFAULT_VOICE=robin

# Optional overrides
# PORT=18892
# DEFAULT_LANGUAGE=auto
# DEFAULT_AUDIO_FORMAT=wav
# CHAT_TEMPERATURE=0.7
# CHAT_MAX_TOKENS=140
# STT_TIMEOUT_SECONDS=60
# CHAT_TIMEOUT_SECONDS=30
# TTS_TIMEOUT_SECONDS=60
# CORS_ALLOWED_ORIGINS=*
# LOG_RETENTION=100
